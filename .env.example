# ============================================================
# team-mcp 환경변수 레퍼런스
#
# 실제 런타임에서는 ~/.claude/.mcp.json 의 env 필드로 주입됨.
# 이 파일은 문서 용도 — 어떤 변수가 있는지 한눈에 보기 위한 것.
#
# [필수] = 해당 서버 사용 시 반드시 설정
# [선택] = 비워두면 기본값 또는 미사용
# ============================================================

# ── evm-mcp ──────────────────────────────────────────────────
EVM_RPC_URL=http://localhost:8545
RPC_TIMEOUT_MS=10000
CONTRACT_ERRORS_PATH=                     # [선택] 에러코드 정의 JSON 경로 (팀 내부 공유)

# ── kafka-mcp ────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092              # [필수]

# ── redis-mcp ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=

# ── slack-mcp ────────────────────────────────────────────────
SLACK_BOT_TOKEN=                          # [필수]
SLACK_USER_TOKEN=
SLACK_DEFAULT_CHANNEL=

# ── grafana-mcp ──────────────────────────────────────────────
GRAFANA_URL=                              # [필수]
GRAFANA_SA_TOKEN=                         # [필수]
GRAFANA_PROM_DATASOURCE_UID=
GRAFANA_LOKI_DATASOURCE_UID=

# ── kibana-mcp ───────────────────────────────────────────────
KIBANA_URL=                               # [필수]
KIBANA_API_KEY=
KIBANA_COOKIE=

# ── dooray-mcp ───────────────────────────────────────────────
DOORAY_TOKEN=                             # [필수]
DOORAY_DEFAULT_PROJECT_ID=
DOORAY_DEFAULT_CHANNEL_ID=

# ── github-wiki-mcp ─────────────────────────────────────────
GITHUB_TOKEN=                             # [필수]
WIKI_REPOS=org/repo1,org/repo2            # [필수]

# ── workflow-mcp ─────────────────────────────────────────────
PROJECT_DIR=
GITHUB_REPO=

# ── rca-mcp ──────────────────────────────────────────────────
KIBANA_URL=                               # [필수] (kibana-mcp과 공유 가능)
KIBANA_API_KEY=
KIBANA_COOKIE=
RPC_TIMEOUT_MS=10000
