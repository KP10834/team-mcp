{
  "name": "@stableteam/team-mcp",
  "version": "1.1.0",
  "description": "Team-shared MCP servers (EVM, Kafka, Redis, Slack, Kibana, Grafana, etc.)",
  "type": "module",
  "bin": {
    "team-mcp": "cli.js"
  },
  "files": [
    "cli.js",
    "setup.js",
    "evm-mcp/index.js",
    "evm-mcp/README.md",
    "kafka-mcp/",
    "redis-mcp/",
    "slack-mcp/",
    "grafana-mcp/",
    "kibana-mcp/",
    "dooray-mcp/",
    "github-wiki-mcp/",
    "workflow-mcp/",
    "rca-mcp/"
  ],
  "scripts": {
    "start:evm": "node evm-mcp/index.js",
    "start:kafka": "node kafka-mcp/index.js",
    "start:redis": "node redis-mcp/index.js",
    "start:slack": "node slack-mcp/index.js",
    "start:grafana": "node grafana-mcp/index.js",
    "start:kibana": "node kibana-mcp/index.js",
    "start:dooray": "node dooray-mcp/index.js",
    "start:github-wiki": "node github-wiki-mcp/index.js",
    "start:workflow": "node workflow-mcp/index.js",
    "start:rca": "node rca-mcp/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slack/web-api": "^7.8.0",
    "better-sqlite3": "11.10.0",
    "ethers": "6.16.0",
    "ioredis": "5.10.0",
    "kafkajs": "2.2.4",
    "zod": "^3.23.0"
  }
}
